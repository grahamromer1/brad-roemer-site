# x402 Payment Configuration
# Toggle x402 payment gating for the /api/book/strategy endpoint.
# Set to "true" in production once WALLET_ADDRESS is configured.
ENABLE_X402=false

# EVM address that receives USDC payments. Use a MetaMask-exported Base address.
WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Network to settle on. "base-sepolia" (testnet) or "base" (mainnet).
X402_NETWORK=base-sepolia
