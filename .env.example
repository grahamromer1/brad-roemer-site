# ── Quiz submission webhook ───────────────────────────────────────────
# Google Apps Script web-app URL that appends a row to the quiz Sheet
# every time someone finishes /quiz. Leave blank in dev — the API route
# will log the payload and return success without forwarding.
# Setup: docs/google-sheets-quiz-setup.md
QUIZ_WEBHOOK_URL=

# ── PostHog analytics ─────────────────────────────────────────────────
# Project API key from https://us.posthog.com/project/settings
# Safe to expose client-side (NEXT_PUBLIC_). Host is the US cloud.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Microsoft Clarity ────────────────────────────────────────────────
# Project ID from https://clarity.microsoft.com. Leave blank to disable.
NEXT_PUBLIC_CLARITY_PROJECT_ID=
